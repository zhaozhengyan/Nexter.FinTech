/* pages/personal/personal.wxss */
@import '../tabBar-template/tabBar-template.wxss';
page {
	background-color: #f5f5f5;
}

/* 用户信息头部 */
.personal_header {
	background-color: #fff;
	padding: 0 28rpx;
}
.personal_info {
	padding: 40rpx 0;
	display: flex;
	flex-direction: row;
	align-items: center;
}
.personal_info .avatar {
	width: 120rpx;
	height: 120rpx;
	border-radius: 50%;
	margin-right: 24rpx;
	background: #e8f4fd;
}
.personal_info .nickName {
	font-size: 40rpx;
	font-weight: bold;
	color: #000;
	line-height: 72rpx;
}
.personal_info .time {
	font-size: 24rpx;
	color: #b1b1b1;
	line-height: 42rpx;
}

/* 统计卡片 */
.stats_row {
	display: flex;
	flex-direction: row;
	align-items: center;
	background: #fff;
	margin: 20rpx 24rpx 0;
	border-radius: 16rpx;
	padding: 32rpx 0;
	box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.stats_cell {
	flex: 1;
	display: flex;
	flex-direction: column;
	align-items: center;
}
.stats_num {
	font-size: 44rpx;
	color: #116cc5;
	font-weight: bold;
	line-height: 56rpx;
}
.stats_label {
	font-size: 22rpx;
	color: #b7b7b7;
	line-height: 36rpx;
	margin-top: 4rpx;
}
.stats_divider {
	width: 1rpx;
	height: 60rpx;
	background: #eee;
}

/* 分组卡片 */
.section_card {
	background: #fff;
	margin: 20rpx 24rpx 0;
	border-radius: 16rpx;
	padding: 0 28rpx;
	box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.section_card:last-child {
	margin-bottom: 140rpx;
}
.section_label {
	font-size: 24rpx;
	color: #999;
	padding: 24rpx 0 0 0;
}

/* 菜单项 */
.personal_item {
	border-bottom: 1px solid #f0f0f0;
	padding: 32rpx 0;
	position: relative;
}
.section_card .personal_item:last-child {
	border-bottom: none;
}
.personal_item text {
	font-size: 30rpx;
	color: #333;
	font-weight: 500;
}
.personal_item .right_arrow {
	width: 14rpx;
	height: 25rpx;
	position: absolute;
	right: 10rpx;
	top: 50%;
	margin-top: -12rpx;
}

/* Radio 单选 */
.radio_group {
	display: flex;
	flex-direction: row;
	padding: 20rpx 0 32rpx 0;
	gap: 56rpx;
}
.radio_option {
	display: flex;
	align-items: center;
	gap: 14rpx;
}
.radio_option text {
	font-size: 28rpx !important;
	color: #666 !important;
	font-weight: normal !important;
}
.radio_selected text {
	color: #116cc5 !important;
	font-weight: 500 !important;
}
.radio_circle {
	width: 36rpx;
	height: 36rpx;
	border-radius: 50%;
	border: 3rpx solid #ccc;
	display: flex;
	align-items: center;
	justify-content: center;
}
.radio_circle_active {
	border-color: #116cc5;
}
.radio_dot {
	width: 20rpx;
	height: 20rpx;
	border-radius: 50%;
	background: #116cc5;
}

/* 未登录引导样式 */
.guest_personal_header {
	background: #fff;
	padding: 60rpx 28rpx;
	display: flex;
	flex-direction: row;
	align-items: center;
}
.guest_avatar_wrap {
	flex-shrink: 0;
}
.guest_avatar_placeholder {
	width: 120rpx;
	height: 120rpx;
	border-radius: 50%;
	background: #e8f4fd;
	display: flex;
	align-items: center;
	justify-content: center;
	border: 3rpx dashed #116cc5;
}
.guest_avatar_icon {
	font-size: 48rpx;
}
.guest_login_text {
	margin-left: 24rpx;
}
.guest_login_title {
	font-size: 36rpx;
	font-weight: bold;
	color: #333;
	margin-bottom: 8rpx;
}
.guest_login_desc {
	font-size: 24rpx;
	color: #999;
}
.guest_login_section {
	padding: 60rpx 24rpx 80rpx;
	text-align: center;
}
.guest_login_btn {
	display: block;
	background: linear-gradient(135deg, #116cc5 0%, #4a9eff 100%);
	color: #fff;
	font-size: 32rpx;
	font-weight: 500;
	height: 88rpx;
	line-height: 88rpx;
	border-radius: 44rpx;
	text-align: center;
	box-shadow: 0 4rpx 16rpx rgba(17,108,197,0.3);
}
.guest_skip_hint {
	display: block;
	font-size: 22rpx;
	color: #bbb;
	margin-top: 20rpx;
}

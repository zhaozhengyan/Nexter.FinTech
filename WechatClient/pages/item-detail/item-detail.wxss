/* pages/item-detail/item-detail.wxss */
@import '/iconfont/remixicon.wxss';

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 详情卡片 */
.detail-card {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.detail-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1a9fe0 0%, #1589c9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.detail-icon .ri {
  font-size: 56rpx;
  color: #fff;
}

.detail-title {
  display: flex;
  flex-direction: column;
}

.detail-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.detail-category {
  font-size: 24rpx;
  color: #999;
}

.detail-stats {
  display: flex;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a9fe0;
}

.detail-info {
  border-top: 1rpx solid #eee;
  padding-top: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

/* 操作按钮 */
.action-bar {
  display: flex;
  gap: 24rpx;
  margin: 40rpx 30rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.edit-btn {
  background: #1a9fe0;
  color: #fff;
}

.delete-btn {
  background: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
}

/* 表单 */
.form-card {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.form-section {
  border-bottom: 1rpx solid #f0f0f0;
}

.form-section:last-child {
  border-bottom: none;
}

.form-row {
  display: flex;
}

.form-item {
  padding: 28rpx 30rpx;
}

.form-item.full {
  width: 100%;
}

.form-item.half {
  width: 50%;
  box-sizing: border-box;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 72rpx;
  font-size: 30rpx;
  color: #333;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.form-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.form-input.small {
  flex: 1;
  width: auto;
}

.add-btn {
  padding: 0 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  white-space: nowrap;
}

.picker-input {
  display: flex;
  justify-content: space-between;
  align-items: center;
  line-height: 72rpx;
}

.arrow {
  color: #ccc;
  font-size: 36rpx;
}

.icon-select {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.icon-select .ri {
  font-size: 36rpx;
  color: #1a9fe0;
}

.icon-name {
  font-size: 26rpx;
  color: #666;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  color: #333;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.bottom-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.cancel-btn {
  background: #fff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
}

.save-btn {
  background: #07c160;
  color: #fff;
}

/* 图标选择弹窗 */
.icon-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.icon-modal-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.icon-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.icon-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.icon-modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  background: #f7f8fa;
}

.icon-item.active {
  background: #e8f7ff;
  border: 2rpx solid #1a9fe0;
}

.icon-item .ri {
  font-size: 48rpx;
  color: #1a9fe0;
  margin-bottom: 8rpx;
}

.icon-label {
  font-size: 22rpx;
  color: #666;
}

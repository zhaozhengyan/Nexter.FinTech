/* pages/item-detail/item-detail.wxss */
@import '/iconfont/remixicon.wxss';

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx;
}

/* 详情卡片 */
.detail-card {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.detail-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1a9fe0 0%, #1589c9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.detail-icon .ri {
  font-size: 56rpx;
  color: #fff;
}

.detail-title {
  display: flex;
  flex-direction: column;
}

.detail-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.detail-category {
  font-size: 24rpx;
  color: #999;
}

.detail-stats {
  display: flex;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a9fe0;
}

.detail-info {
  border-top: 1rpx solid #eee;
  padding-top: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

/* 操作按钮 */
.action-bar {
  display: flex;
  gap: 24rpx;
  margin: 40rpx 30rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.edit-btn {
  background: #1a9fe0;
  color: #fff;
}

.delete-btn {
  background: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
}

/* 表单 */
.form-card {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.form-section {
  border-bottom: 1rpx solid #f0f0f0;
}

.form-section:last-child {
  border-bottom: none;
}

.form-row {
  display: flex;
}

.form-item {
  padding: 28rpx 30rpx;
}

.form-item.full {
  width: 100%;
}

.form-item.half {
  width: 50%;
  box-sizing: border-box;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 72rpx;
  font-size: 30rpx;
  color: #333;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.form-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.form-input.small {
  flex: 1;
  width: auto;
}

.add-btn {
  padding: 0 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  white-space: nowrap;
}

.picker-input {
  display: flex;
  justify-content: space-between;
  align-items: center;
  line-height: 72rpx;
}

.arrow {
  color: #ccc;
  font-size: 36rpx;
}

.icon-select {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.icon-select .ri {
  font-size: 36rpx;
  color: #1a9fe0;
}

.icon-name {
  font-size: 26rpx;
  color: #666;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  color: #333;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 附加项列表 */
.additional-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.additional-add-btn {
  padding: 8rpx 24rpx;
  background: #07c160;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 40px;
}

.additional-list {
  margin-top: 12rpx;
}

.additional-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.additional-item:last-child {
  border-bottom: none;
}

.additional-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.additional-name {
  font-size: 28rpx;
  color: #333;
}

.additional-type {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.type-income {
  background: #e8f8ef;
  color: #07c160;
}

.type-expense {
  background: #fde8e8;
  color: #ff4d4f;
}

.additional-item-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.additional-amount {
  font-size: 28rpx;
  font-weight: 500;
}

.amount-income {
  color: #07c160;
}

.amount-expense {
  color: #ff4d4f;
}

.additional-date {
  font-size: 24rpx;
  color: #999;
}

.additional-delete {
  font-size: 28rpx;
  color: #ccc;
  padding: 8rpx;
}

/* 详情模式附加项 */
.detail-additionals {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #eee;
}

.detail-additionals-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.detail-additional-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.detail-additional-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-additional-name {
  font-size: 26rpx;
  color: #666;
}

.detail-additional-type {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

.detail-additional-amount {
  font-size: 28rpx;
  font-weight: 500;
}

.detail-additional-summary {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #eee;
  font-size: 26rpx;
  color: #1a9fe0;
  font-weight: 500;
}

/* 附加项编辑弹窗 */
.additional-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1100;
}

.additional-modal-content {
  width: 85%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.additional-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 36rpx;
}

.additional-form-item {
  margin-bottom: 28rpx;
}

.additional-form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.additional-form-input {
  width: 100%;
  height: 72rpx;
  font-size: 28rpx;
  color: #333;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.additional-type-toggle {
  display: flex;
  gap: 16rpx;
}

.additional-type-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #f7f8fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.type-active-expense {
  background: #fde8e8;
  color: #ff4d4f;
  border-color: #ff4d4f;
  font-weight: 500;
}

.type-active-income {
  background: #e8f8ef;
  color: #07c160;
  border-color: #07c160;
  font-weight: 500;
}

.additional-form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.additional-modal-footer {
  display: flex;
  gap: 24rpx;
  margin-top: 36rpx;
}

.additional-modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 30rpx;
}

.additional-modal-btn.cancel {
  color: #666;
  background: #f7f8fa;
}

.additional-modal-btn.confirm {
  color: #fff;
  background: #1a9fe0;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.bottom-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.cancel-btn {
  background: #fff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
}

.save-btn {
  background: #07c160;
  color: #fff;
}

/* 图标选择弹窗 */
.icon-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.icon-modal-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.icon-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.icon-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.icon-modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  background: #f7f8fa;
}

.icon-item.active {
  background: #e8f7ff;
  border: 2rpx solid #1a9fe0;
}

.icon-item .ri {
  font-size: 48rpx;
  color: #1a9fe0;
  margin-bottom: 8rpx;
}

.icon-label {
  font-size: 22rpx;
  color: #666;
}

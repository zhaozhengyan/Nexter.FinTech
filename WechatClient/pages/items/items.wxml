<!--pages/items/items.wxml-->
<import src='../tabBar-template/tabBar-template.wxml' />

<!-- 未登录：引导体验界面 -->
<view class="container" wx:if="{{!loggedIn}}">
  <view class="guest_banner">
    <view class="guest_banner_icon">📦</view>
    <view class="guest_banner_title">物品管理</view>
    <view class="guest_banner_desc">记录你的每一件物品，计算日均使用成本，让消费更理性</view>
  </view>

  <view class="guest_feature_list">
    <view class="guest_feature_item">
      <view class="guest_feature_icon">💎</view>
      <view class="guest_feature_text">
        <view class="guest_feature_name">物品记录</view>
        <view class="guest_feature_desc">添加物品信息，分类管理你的所有物品</view>
      </view>
    </view>
    <view class="guest_feature_item">
      <view class="guest_feature_icon">📈</view>
      <view class="guest_feature_text">
        <view class="guest_feature_name">成本分析</view>
        <view class="guest_feature_desc">自动计算日均使用成本，了解物品性价比</view>
      </view>
    </view>
    <view class="guest_feature_item">
      <view class="guest_feature_icon">🔄</view>
      <view class="guest_feature_text">
        <view class="guest_feature_name">排序筛选</view>
        <view class="guest_feature_desc">按时间、价格、名称灵活排列物品</view>
      </view>
    </view>
  </view>

  <view class="guest_login_section">
    <navigator url='/pages/login/login' class="guest_login_btn">
      <text>立即登录，开始使用</text>
    </navigator>
    <text class="guest_skip_hint">登录后数据自动同步，不登录也可浏览体验</text>
  </view>
</view>

<!-- 已登录：正常物品页面 -->
<view class="container" wx:else>
  <!-- 顶部统计卡片 -->
  <view class="stats-card">
    <view class="stats-header">
      <view class="stats-title">
        <text class="stats-count">共 {{totalCount}} 件物品</text>
      </view>
      <view class="stats-actions">
        <view class="action-btn" bindtap="onFilterTap">{{categoryName || '筛选'}}</view>
        <view class="action-btn" bindtap="onSortTap">排序</view>
      </view>
    </view>
    <view class="stats-content">
      <view class="stat-item">
        <text class="stat-label">总资产</text>
        <text class="stat-value">¥{{totalAsset}}</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-label">日均成本</text>
        <view class="stat-value-row">
          <text class="stat-value">¥{{dailyCost}}</text>
          <text class="stat-unit">/天</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 物品列表 -->
  <view class="item-list">
    <view class="item-card" wx:for="{{items}}" wx:key="id" bindtap="onItemTap" data-id="{{item.id}}">
      <view class="item-icon">
        <text class="ri {{item.icon}}" wx:if="{{item.icon}}"></text>
        <text class="item-icon-text" wx:else>{{item.name[0] || '?'}}</text>
      </view>
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <view class="item-price-row">
          <text class="item-price">¥{{item.price}}</text>
          <text class="item-daily">¥{{item.dailyCost}}/天</text>
        </view>
      </view>
      <view class="item-days">
        <text class="days-number">{{item.days}}</text>
        <text class="days-unit">天</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{items.length === 0 && !loading}}">
    <text class="empty-icon">📦</text>
    <text class="empty-text">还没有添加物品</text>
    <text class="empty-hint">点击下方 + 号添加你的第一个物品</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>

<template is='tabBarTemplate' data='{{...tabBarSelected}}' />

<!--pages/items/items.wxml-->
<import src='../tabBar-template/tabBar-template.wxml' />

<!-- 未登录：引导体验界面 -->
<view class="container" wx:if="{{!loggedIn}}">
  <view class="guest_banner">
    <view class="guest_banner_icon">📦</view>
    <view class="guest_banner_title">物品管理</view>
    <view class="guest_banner_desc">记录你的每一件物品，计算日均使用成本，让消费更理性</view>
  </view>

  <view class="guest_feature_list">
    <view class="guest_feature_item">
      <view class="guest_feature_icon">💎</view>
      <view class="guest_feature_text">
        <view class="guest_feature_name">物品记录</view>
        <view class="guest_feature_desc">添加物品信息，分类管理你的所有物品</view>
      </view>
    </view>
    <view class="guest_feature_item">
      <view class="guest_feature_icon">📈</view>
      <view class="guest_feature_text">
        <view class="guest_feature_name">成本分析</view>
        <view class="guest_feature_desc">自动计算日均使用成本，了解物品性价比</view>
      </view>
    </view>
    <view class="guest_feature_item">
      <view class="guest_feature_icon">🔄</view>
      <view class="guest_feature_text">
        <view class="guest_feature_name">排序筛选</view>
        <view class="guest_feature_desc">按时间、价格、名称灵活排列物品</view>
      </view>
    </view>
  </view>

  <view class="guest_login_section">
    <navigator url='/pages/login/login' class="guest_login_btn">
      <text>立即登录，开始使用</text>
    </navigator>
    <text class="guest_skip_hint">登录后数据自动同步，不登录也可浏览体验</text>
  </view>
</view>

<!-- 已登录：正常物品页面 -->
<view class="container" wx:else>
  <!-- 顶部统计卡片 -->
  <view class="stats-card">
    <view class="stats-header">
      <view class="stats-title">
        <text class="stats-count">共 {{totalCount}} 件物品</text>
      </view>
      <view class="stats-actions">
        <view class="action-btn {{hasFilter ? 'active' : ''}}" bindtap="onFilterTap">筛选</view>
        <view class="action-btn {{sortBy === 'custom' ? 'active' : ''}}" bindtap="onSortTap">排序</view>
      </view>
    </view>
    <view class="stats-content">
      <view class="stat-item">
        <text class="stat-label">总资产</text>
        <text class="stat-value">¥{{totalAsset}}</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-label">日均成本</text>
        <view class="stat-value-row">
          <text class="stat-value">¥{{dailyCost}}</text>
          <text class="stat-unit">/天</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 拖拽排序提示 -->
  <view class="sort-hint" wx:if="{{sortBy === 'custom'}}">
    <text>长按拖拽手柄可调整顺序</text>
  </view>

  <!-- 物品列表 -->
  <scroll-view scroll-y="{{!isDragging}}" class="item-list-scroll" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="item-list">
      <view class="item-card {{item.retireDate ? 'retired' : ''}} {{sortBy === 'custom' ? 'sortable' : ''}} {{dragCurrentIndex === index ? 'dragging' : ''}} {{isDragging && dragCurrentIndex !== index && dragTargetIndex !== dragCurrentIndex && ((dragCurrentIndex > dragTargetIndex && index >= dragTargetIndex && index < dragCurrentIndex) || (dragCurrentIndex < dragTargetIndex && index > dragCurrentIndex && index <= dragTargetIndex)) ? (dragCurrentIndex > dragTargetIndex ? 'shifted-down' : 'shifted-up') : ''}}"
            wx:for="{{items}}" wx:key="id"
            bindtap="onItemTap" data-id="{{item.id}}"
            bindtouchstart="onTouchStart">
        <view class="drag-handle" wx:if="{{sortBy === 'custom'}}" data-drag="1" data-id="{{item.id}}" catchtouchstart="onTouchStart">
          <view class="drag-dots">
            <view class="drag-dot-row"><view class="drag-dot"></view><view class="drag-dot"></view></view>
            <view class="drag-dot-row"><view class="drag-dot"></view><view class="drag-dot"></view></view>
            <view class="drag-dot-row"><view class="drag-dot"></view><view class="drag-dot"></view></view>
          </view>
        </view>
        <view class="item-icon">
          <text class="ri {{item.icon}}" wx:if="{{item.icon}}"></text>
          <text class="item-icon-text" wx:else>{{item.name[0] || '?'}}</text>
        </view>
        <view class="item-info">
          <view class="item-name-row">
            <text class="item-name">{{item.name}}</text>
            <text class="retired-badge" wx:if="{{item.retireDate}}">已退役</text>
          </view>
          <view class="item-price-row">
            <text class="item-price">¥{{item.price}}</text>
            <text class="item-daily">¥{{item.dailyCost}}/天</text>
          </view>
        </view>
        <view class="item-days">
          <text class="days-number">{{item.days}}</text>
          <text class="days-unit">天</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{items.length === 0 && !loading}}">
    <text class="empty-icon">📦</text>
    <text class="empty-text">还没有添加物品</text>
    <text class="empty-hint">点击下方 + 号添加你的第一个物品</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 拖拽浮层 -->
  <view class="drag-overlay" wx:if="{{isDragging}}" catchtouchmove="onTouchMove" catchtouchend="onTouchEnd">
    <view class="drag-clone item-card" style="position:fixed;left:24rpx;right:24rpx;top:{{dragCloneY}}px;z-index:999;box-shadow:0 8rpx 32rpx rgba(0,0,0,0.15);">
      <view class="item-icon">
        <text class="ri {{items[dragCurrentIndex].icon}}" wx:if="{{items[dragCurrentIndex].icon}}"></text>
        <text class="item-icon-text" wx:else>{{items[dragCurrentIndex].name[0] || '?'}}</text>
      </view>
      <view class="item-info">
        <view class="item-name-row">
          <text class="item-name">{{items[dragCurrentIndex].name}}</text>
          <text class="retired-badge" wx:if="{{items[dragCurrentIndex].retireDate}}">已退役</text>
        </view>
        <view class="item-price-row">
          <text class="item-price">¥{{items[dragCurrentIndex].price}}</text>
          <text class="item-daily">¥{{items[dragCurrentIndex].dailyCost}}/天</text>
        </view>
      </view>
      <view class="item-days">
        <text class="days-number">{{items[dragCurrentIndex].days}}</text>
        <text class="days-unit">天</text>
      </view>
    </view>
  </view>

  <!-- 筛选遮罩 -->
  <view class="filter-mask" wx:if="{{showFilter}}" bindtap="onCloseFilter"></view>

  <!-- 筛选面板 -->
  <view class="filter-panel {{showFilter ? 'show' : ''}}">
    <view class="filter-header">
      <text class="filter-title">筛选条件</text>
      <text class="filter-clear" bindtap="onClearFilter">清空</text>
    </view>

    <!-- 物品名称搜索 -->
    <view class="filter-section">
      <text class="filter-label">物品名称</text>
      <input class="filter-search-input" placeholder="搜索物品名称" value="{{filterName}}" bindinput="onFilterNameInput"/>
    </view>

    <!-- 物品状态 -->
    <view class="filter-section">
      <text class="filter-label">物品状态</text>
      <view class="filter-tags">
        <view class="filter-tag {{filterStatus === 'active' ? 'active' : ''}}" bindtap="onFilterStatusTap" data-status="active">现役物品</view>
        <view class="filter-tag {{filterStatus === 'retired' ? 'active' : ''}}" bindtap="onFilterStatusTap" data-status="retired">退役物品</view>
      </view>
    </view>

    <!-- 物品分类 -->
    <view class="filter-section">
      <text class="filter-label">物品分类</text>
      <view class="filter-tags">
        <view class="filter-tag {{filterCategoryId == item.id ? 'active' : ''}}" 
              wx:for="{{categories}}" wx:key="id" 
              bindtap="onFilterCategoryTap" data-id="{{item.id}}">{{item.name}}</view>
      </view>
    </view>

    <!-- 确定按钮 -->
    <view class="filter-confirm-btn" bindtap="onConfirmFilter">确定</view>
  </view>
</view>

<template is='tabBarTemplate' data='{{...tabBarSelected}}' />

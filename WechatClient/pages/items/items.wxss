/* pages/items/items.wxss */
@import '../tabBar-template/tabBar-template.wxss';
@import '/iconfont/remixicon.wxss';

page {
  background-color: #116cc5;
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #116cc5 0%, #f5f5f5 28%);
  padding-bottom: 140rpx;
}

/* 统计卡片 */
.stats-card {
  margin: 20rpx 24rpx 0;
  background: linear-gradient(135deg, #116cc5 0%, #0f5daa 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(17, 108, 197, 0.3);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.stats-title {
  display: flex;
  align-items: center;
}

.stats-count {
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
}

.stats-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 10rpx 28rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  color: #fff;
  font-size: 24rpx;
}

.action-btn.active {
  background: rgba(255, 255, 255, 0.45);
  font-weight: 500;
}

.stats-content {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.stat-value {
  color: #fff;
  font-size: 42rpx;
  font-weight: bold;
}

.stat-value-row {
  display: flex;
  align-items: baseline;
}

.stat-unit {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
  margin-left: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.25);
  margin: 0 24rpx;
}

/* 物品列表 */
.item-list {
  padding: 16rpx 24rpx 0;
}

.item-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.item-card:active {
  opacity: 0.85;
}

/* 退役物品灰色样式 */
.item-card.retired {
  background: #ededed;
}

.item-card.retired .item-icon {
  background: #ddd;
  opacity: 0.6;
}

.item-card.retired .item-icon .ri,
.item-card.retired .item-icon-text {
  color: #aaa;
}

.item-card.retired .item-name {
  color: #999;
}

.item-card.retired .item-price,
.item-card.retired .item-daily {
  color: #b5b5b5;
}

.item-card.retired .item-days {
  opacity: 0.4;
}

.retired-badge {
  display: inline-block;
  font-size: 20rpx;
  color: #bbb;
  background: #dcdcdc;
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
  margin-left: 12rpx;
  vertical-align: middle;
  line-height: 1.4;
}

.item-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 18rpx;
  background: #e8f4fd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.item-icon-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #116cc5;
}

.item-icon .ri {
  font-size: 40rpx;
  color: #116cc5;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.item-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.item-price {
  font-size: 26rpx;
  color: #333;
}

.item-daily {
  font-size: 24rpx;
  color: #999;
}

.item-days {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 24rpx;
  flex-shrink: 0;
}

.days-number {
  font-size: 44rpx;
  font-weight: bold;
  color: #116cc5;
  line-height: 1;
}

.days-unit {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

/* 筛选面板 */
.filter-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 200;
}

.filter-panel {
  position: fixed;
  top: 0;
  right: -600rpx;
  width: 560rpx;
  height: 100vh;
  background: #fff;
  z-index: 201;
  transition: right 0.3s ease;
  display: flex;
  flex-direction: column;
  box-shadow: -4rpx 0 24rpx rgba(0, 0, 0, 0.1);
}

.filter-panel.show {
  right: 0;
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.filter-clear {
  font-size: 26rpx;
  color: #999;
}

.filter-section {
  padding: 28rpx 32rpx;
}

.filter-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.filter-search-input {
  width: 100%;
  height: 72rpx;
  font-size: 28rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  color: #333;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-tag {
  padding: 14rpx 32rpx;
  background: #f7f8fa;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.filter-tag.active {
  background: #e8f4fd;
  color: #116cc5;
  border-color: #116cc5;
  font-weight: 500;
}

.filter-confirm-btn {
  margin: auto 32rpx 60rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #116cc5;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* 未登录引导样式 */
.guest_banner {
  background: linear-gradient(135deg, #116cc5 0%, #4a9eff 100%);
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 48rpx 36rpx;
  text-align: center;
}
.guest_banner_icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}
.guest_banner_title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}
.guest_banner_desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  line-height: 40rpx;
}
.guest_feature_list {
  margin: 0 24rpx;
}
.guest_feature_item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #fff;
  padding: 30rpx 28rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.guest_feature_icon {
  font-size: 44rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.guest_feature_text {
  flex: 1;
}
.guest_feature_name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}
.guest_feature_desc {
  font-size: 24rpx;
  color: #999;
}
.guest_login_section {
  padding: 40rpx 24rpx 60rpx;
  text-align: center;
}
.guest_login_btn {
  display: block;
  background: linear-gradient(135deg, #116cc5 0%, #4a9eff 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(17,108,197,0.3);
}
.guest_skip_hint {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 20rpx;
}

/* 拖拽排序 */
.item-list-scroll {
  height: calc(100vh - 340rpx);
}

.sort-hint {
  text-align: center;
  padding: 12rpx 0 0;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.item-name-row {
  display: flex;
  align-items: center;
}

.item-card.sortable {
  padding-left: 16rpx;
  transition: transform 0.15s ease;
}

.drag-handle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  padding: 8rpx 0;
}

.drag-dots {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.drag-dot-row {
  display: flex;
  gap: 6rpx;
}

.drag-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #ccc;
}

.item-card.dragging {
  opacity: 0.3;
}

.item-card.shifted-down {
  transform: translateY(100%);
  transition: transform 0.15s ease;
}

.item-card.shifted-up {
  transform: translateY(-100%);
  transition: transform 0.15s ease;
}

.drag-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 998;
}

.drag-clone {
  pointer-events: none;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 0;
}

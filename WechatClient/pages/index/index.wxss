/* pages/index/index.wxss */
@import '/iconfont/iconfont.wxss';
@import '../tabBar-template/tabBar-template.wxss';
page {
	background-color: #f5f5f5;
	width: 100%;
	height: 100%;
}
.index {
	position: relative;
	width: 100%;
	height: 100%;
}
.index_header {
	background-color: #116cc5;
	padding: 30rpx;

}
.index_filter {
	overflow: hidden;
}
.picker_filter {
	float: left;
}
.picker_filter .picker text {
	color: #fff;
	font-size: 44rpx;
	vertical-align: middle;
}
.picker_filter .date_arrow {
	width: 32rpx;
	height: 32rpx;
	vertical-align: middle;
	margin-left: 15rpx;
}
.filter_btn {
	width: 50rpx;
	height: 50rpx;
	float: right;
}
.index_header .text {
	color: #fff;
	margin-top: 42rpx;
}
.index_header .text text {
	color: #fcfefb;
	font-size: 30rpx;
}
.index_header .text text.large {
	font-size: 54rpx;
	color: #fff;
}
.index_header .text text.margin_right {
	margin-right: 42rpx;
}

.tally_book_list {
	background-color: #fff;
	position: absolute;
	left: 0;
	right: 0;
	top: 324rpx;
	bottom: 98rpx;
	width: 100%;
}
.tally_book_date {
	padding: 0 30rpx;
	background-color: #ececec;
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	height: 58rpx;
	line-height: 58rpx;
}
.tally_book_date text {
	color: #7d807f;
	font-size: 28rpx;
}
.tally_book_item {
	border-top: 1px solid #ececec;
	background-color: #fff;
	overflow: hidden;
	padding: 23rpx 30rpx;
}
.tally_book_item .iconfont_container {
	float: left;
}
.tally_book_item .text_wrap {
	float: left;
	padding-left: 36rpx;
}
.tally_book_item .text_wrap .icon_title {
	font-size: 32rpx;
	color: #333;
}
.tally_book_item .text_wrap .text {
	font-size: 22rpx;
	color: #999;
}
.tally_book_item .money {
	float: right;
	font-size: 30rpx;
	font-weight: bold;
	margin-top: 18rpx;
}
.tally_book_item .money.black {
	color: #333;
}
.tally_book_item .money.blue {
	color: #116cc5;
}
.tally_book_item .money.red {
	color: red;
}

.filter_module_bg {
	width: 100%;
	height: 100%;
	position: fixed;
	left: 0;
	top: 0;
	background-color: rgba(0,0,0,0.1);
}
.filter_module {
	width: 100%;
	position: fixed;
	left: 0;
	bottom: 0;
	background-color: #e8e9eb;
	transform: translateY(100%);
	transition: 0.3s;
}
.filter_module.show {
	transform: translateY(0);
}
.filter_module_title {
	width: 100%;
	height: 108rpx;
	line-height: 108rpx;
	text-align: center;
	color: #000;
	font-size: 32rpx;
	background-color: #fff;
	border-bottom: 1px solid #ededed;
}
.filter_module_content {
	background-color: #fff;
	height: 500rpx;
}
.filter_module_cancle {
	width: 100%;
	height: 104rpx;
	line-height: 104rpx;
	text-align: center;
	color: #000;
	font-size: 32rpx;
	background-color: #fff;
	margin-top: 14rpx;
}

/* 未登录引导样式 */
.guest_tally_book {
	position: absolute;
	left: 0;
	right: 0;
	top: 324rpx;
	bottom: 98rpx;
	width: 100%;
	background-color: #f5f5f5;
	overflow-y: auto;
}
.guest_banner {
	background: linear-gradient(135deg, #116cc5 0%, #4a9eff 100%);
	margin: 24rpx;
	border-radius: 20rpx;
	padding: 48rpx 36rpx;
	text-align: center;
}
.guest_banner_icon {
	font-size: 72rpx;
	margin-bottom: 16rpx;
}
.guest_banner_title {
	font-size: 36rpx;
	font-weight: bold;
	color: #fff;
	margin-bottom: 12rpx;
}
.guest_banner_desc {
	font-size: 26rpx;
	color: rgba(255,255,255,0.85);
	line-height: 40rpx;
}
.guest_feature_list {
	margin: 0 24rpx;
}
.guest_feature_item {
	display: flex;
	flex-direction: row;
	align-items: center;
	background: #fff;
	padding: 30rpx 28rpx;
	margin-bottom: 16rpx;
	border-radius: 16rpx;
	box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.guest_feature_icon {
	font-size: 44rpx;
	margin-right: 24rpx;
	flex-shrink: 0;
}
.guest_feature_text {
	flex: 1;
}
.guest_feature_name {
	font-size: 30rpx;
	font-weight: 500;
	color: #333;
	margin-bottom: 6rpx;
}
.guest_feature_desc {
	font-size: 24rpx;
	color: #999;
}
.guest_login_section {
	padding: 40rpx 24rpx 60rpx;
	text-align: center;
}
.guest_login_btn {
	display: block;
	background: linear-gradient(135deg, #116cc5 0%, #4a9eff 100%);
	color: #fff;
	font-size: 32rpx;
	font-weight: 500;
	height: 88rpx;
	line-height: 88rpx;
	border-radius: 44rpx;
	text-align: center;
	box-shadow: 0 4rpx 16rpx rgba(17,108,197,0.3);
}
.guest_skip_hint {
	display: block;
	font-size: 22rpx;
	color: #bbb;
	margin-top: 20rpx;
}
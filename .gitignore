## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates
*.mp3

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
Logs/
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
node_modules 
.bin/
.vs/
[Bb]in/
[Oo]bj/
[Bb]uild/
artifacts/

# NuGet Packages
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json

# .NET Core
project.nuget.cache

# Visual Studio
.vs/
*.dbmdl
*.jfm
launchSettings.json.local

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Rider
.idea/

# VS Code
.vscode/

# macOS
.DS_Store

# Logs
*.log
*.vspscc
*.vssscc
*.scc
key-*.xml
~$*

